---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllTags, loadAssets } from '../lib/assets.js';
import { withBase } from '../lib/url.js';

const assets = loadAssets();
const tags = getAllTags(assets);
const featuredCount = assets.length;
---

<BaseLayout
  title="GS-Hub | 3DGS 素材库"
  description="公开访问的 3DGS 素材大厅，支持关键字搜索、标签筛选和网盘下载跳转。"
>
  <section class="asset-grid asset-grid--catalog">
    <section class="asset-card asset-card--wide search-card">
      <div class="search-card__controls">
        <label class="search-box">
          <input
            data-search
            type="search"
            placeholder="按名称、作者或标签搜索"
            autocomplete="off"
          />
        </label>

        <div class="tag-toolbar" aria-label="标签筛选">
          <button class="tag-chip is-active" data-tag-button data-tag="all" type="button">全部</button>
          {
            tags.map((tag) => (
              <button class="tag-chip" data-tag-button data-tag={tag} type="button">
                {tag}
              </button>
            ))
          }
        </div>
      </div>
    </section>

    {
      assets.map((asset) => (
        <a
          class="asset-card asset-card--link"
          data-asset-card
          data-title={asset.title.toLowerCase()}
          data-author={asset.author.toLowerCase()}
          data-tags={asset.tags.join(' ').toLowerCase()}
          data-tag-list={asset.tags.join('|')}
          href={withBase(`/assets/${asset.id}/`)}
        >
          <div class="asset-card__media">
            <img
              src={withBase(asset.thumbnail)}
              alt={`${asset.title} 缩略图`}
              loading="lazy"
              width="640"
              height="420"
            />
          </div>
          <div class="asset-card__body">
            <div class="asset-card__meta">
              <span>{asset.author}</span>
              <span>{asset.id}</span>
            </div>
            <h2>{asset.title}</h2>
            <p>{asset.summary ?? '暂无摘要，点击进入详情页查看素材说明。'}</p>
            <div class="tag-list">
              {asset.tags.map((tag) => <span class="mini-tag">{tag}</span>)}
            </div>
          </div>
        </a>
      ))
    }
  </section>

  <section class="empty-state" data-empty-result hidden={assets.length > 0}>
    <h2>没有符合条件的素材</h2>
    <p>可以试试缩短关键词，或者切回“全部”标签重新查看。</p>
  </section>
</BaseLayout>

<script>
  const searchInput = document.querySelector('[data-search]');
  const tagButtons = [...document.querySelectorAll('[data-tag-button]')];
  const cards = [...document.querySelectorAll('[data-asset-card]')];
  const emptyResult = document.querySelector('[data-empty-result]');

  let activeTag = 'all';

  const applyFilters = () => {
    const query = (searchInput?.value ?? '').trim().toLowerCase();
    let visibleCount = 0;

    cards.forEach((card) => {
      const haystack = `${card.dataset.title ?? ''} ${card.dataset.author ?? ''} ${card.dataset.tags ?? ''}`;
      const tagList = (card.dataset.tagList ?? '').split('|').filter(Boolean);
      const matchesQuery = !query || haystack.includes(query);
      const matchesTag = activeTag === 'all' || tagList.includes(activeTag);
      const isVisible = matchesQuery && matchesTag;

      card.hidden = !isVisible;

      if (isVisible) {
        visibleCount += 1;
      }
    });

    if (emptyResult) {
      emptyResult.hidden = visibleCount > 0;
    }
  };

  searchInput?.addEventListener('input', applyFilters);

  tagButtons.forEach((button) => {
    button.addEventListener('click', () => {
      activeTag = button.dataset.tag ?? 'all';

      tagButtons.forEach((candidate) => {
        candidate.classList.toggle('is-active', candidate === button);
      });

      applyFilters();
    });
  });
</script>
